# RegiMenu Chat — copy to .env and fill in real values. .env is gitignored.
#
# Two ways to inject these into the Flutter app:
#   1. flutter_dotenv loads this file at runtime (current setup) — it is bundled
#      as an asset via pubspec.yaml.
#   2. CI / Netlify build can pass values via `--dart-define` from the build env.
#
# For local dev:
#   - Add http://localhost:5000 to Auth0 Allowed Callback / Logout / Web Origin URLs
#     on the SPA app in the Auth0 dashboard.
#   - Run: flutter run -d chrome --web-port=5000

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_AUDIENCE=https://your-api-audience
# API_BASE_URL is the regi-api base. /tts and /ai/chat/stream both hang off this.
API_BASE_URL=https://api.example.com/api
