# RegiMenu Chat — env reference (NOT loaded at runtime).
#
# All config flows through --dart-define. lib/config.dart reads each value
# with const String.fromEnvironment(...). There is no runtime .env loader.
#
# Local dev:
#   flutter run -d chrome --web-port=5000 \
#     --dart-define=AUTH0_DOMAIN=$AUTH0_DOMAIN \
#     --dart-define=AUTH0_CLIENT_ID=$AUTH0_CLIENT_ID \
#     --dart-define=AUTH0_AUDIENCE=$AUTH0_AUDIENCE \
#     --dart-define=API_BASE_URL=$API_BASE_URL
#
# Netlify: same keys live in Site settings → Environment variables.
# netlify.toml expands them into --dart-define args at build time.
#
# Auth0 dashboard for the SPA app must allow the client URL:
#   - Local: http://localhost:5000 in Callback / Logout / Web Origin URLs
#   - Prod:  https://<netlify-domain> in the same three slots

AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_spa_client_id
# IMPORTANT: AUTH0_AUDIENCE is the API identifier in Auth0 (no /api suffix);
# API_BASE_URL is the actual REST base (with /api). They differ on purpose.
AUTH0_AUDIENCE=https://api.example.com
API_BASE_URL=https://api.example.com/api
